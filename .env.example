# ═══════════════════════════════════════════════════════════
#  SmartScrapeAI v2.0 — Environment Variables
#  Copy file ini ke .env dan isi sesuai kebutuhan
# ═══════════════════════════════════════════════════════════

# Port server (default: 8080)
PORT=8080

# Environment
NODE_ENV=production

# Timezone
TZ=Asia/Jakarta

# ── AI Provider API Keys (isi yang kamu pakai) ──
# API Key diinput langsung di UI, tidak perlu set di sini
# Tapi bisa juga di-set sebagai default:

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...
# DEEPSEEK_API_KEY=sk-...
# MISTRAL_API_KEY=...
# XAI_API_KEY=xai-...
