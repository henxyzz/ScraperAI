# ═══════════════════════════════════════════════════════════
#  SmartScrapeAI v4.0 — Environment Variables
#  Copy ke .env dan sesuaikan
# ═══════════════════════════════════════════════════════════

PORT=8080
NODE_ENV=development
TZ=Asia/Jakarta

# ── AI Provider API Keys (bisa juga diinput di UI) ──────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...
# DEEPSEEK_API_KEY=sk-...
# MISTRAL_API_KEY=...
# XAI_API_KEY=xai-...

# ── C3 Storage (Cloudflare R2 / S3-compatible) ─────────────
# Opsional. Aktifkan untuk sync scraper ke cloud storage.
# Buat R2 bucket di Cloudflare Dashboard -> R2 -> Create bucket
# Buat API Token di Manage R2 API Tokens -> Create API Token
#
# C3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# C3_BUCKET=smartscrapeai
# C3_ACCESS_KEY=your-r2-access-key-id
# C3_SECRET_KEY=your-r2-secret-access-key
# C3_PUBLIC_URL=https://pub.yourdomain.com   (opsional, jika bucket public)
# C3_FILE_KEY=scrapers.json                  (nama file di bucket)
