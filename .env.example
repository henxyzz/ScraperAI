PORT=8080
NODE_ENV=development
TZ=Asia/Jakarta

# API Key bisa diinput langsung di UI.
# Atau set di sini sebagai default server-side:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...
# DEEPSEEK_API_KEY=sk-...
# MISTRAL_API_KEY=...
# XAI_API_KEY=xai-...
