# ═══════════════════════════════════════════════════════════
#  SmartScrapeAI v4.0 — Environment Variables
#  Salin ke .env dan sesuaikan (dev lokal).
#  Untuk Clever Cloud / Railway / Render: set di dashboard ENV panel.
# ═══════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
TZ=Asia/Jakarta

# ── Admin Panel Auth ────────────────────────────────────────
# Wajib diubah sebelum deploy ke production!
# ADMIN_USER=admin
# ADMIN_PASS=ganti_password_anda

# ── AI Provider API Keys (bisa juga diinput di UI) ──────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...
# DEEPSEEK_API_KEY=sk-...
# MISTRAL_API_KEY=...
# XAI_API_KEY=xai-...

# ── C3 Storage (Cloudflare R2 / S3-compatible) ─────────────
# Opsional. Aktifkan untuk sync scraper ke cloud storage.
# C3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# C3_BUCKET=smartscrapeai
# C3_ACCESS_KEY=your-r2-access-key-id
# C3_SECRET_KEY=your-r2-secret-access-key
# C3_PUBLIC_URL=https://pub.yourdomain.com
# C3_FILE_KEY=scrapers.json
